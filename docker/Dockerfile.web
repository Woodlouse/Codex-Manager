# syntax=docker/dockerfile:1.5
FROM node:20-bookworm-slim AS ui

WORKDIR /src/apps

RUN corepack enable && corepack prepare pnpm@9.0.0 --activate

COPY apps/package.json apps/pnpm-lock.yaml apps/vite.config.js apps/index.html ./
COPY apps/src ./src
COPY apps/tests ./tests
COPY apps/scripts ./scripts

ENV PNPM_STORE_PATH=/root/.pnpm-store
RUN --mount=type=cache,target=/root/.pnpm-store \
    pnpm install --frozen-lockfile
RUN pnpm run build

FROM rust:1-bookworm AS builder

WORKDIR /src

COPY Cargo.toml Cargo.lock ./
COPY crates ./crates

COPY --from=ui /src/apps/dist ./apps/dist

ARG CARGO_BUILD_FLAGS=--release
ARG CARGO_BIN_DIR=release
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    --mount=type=cache,target=/src/target \
    cargo build -p codexmanager-web --features embedded-ui ${CARGO_BUILD_FLAGS} && \
    mkdir -p /out && \
    install -m 755 /src/target/${CARGO_BIN_DIR}/codexmanager-web /out/codexmanager-web

FROM debian:bookworm-slim

WORKDIR /app

ARG CARGO_BIN_DIR=release

ARG APT_MIRROR
ARG APT_SECURITY_MIRROR
RUN set -e; \
    sources="/etc/apt/sources.list"; \
    if [ -f /etc/apt/sources.list.d/debian.sources ]; then \
      sources="/etc/apt/sources.list.d/debian.sources"; \
    fi; \
    if [ -n "$APT_MIRROR" ] && [ -f "$sources" ]; then \
      sed -i "s|http://deb.debian.org/debian|$APT_MIRROR|g; s|https://deb.debian.org/debian|$APT_MIRROR|g" "$sources"; \
    fi; \
    if [ -n "$APT_SECURITY_MIRROR" ] && [ -f "$sources" ]; then \
      sed -i "s|http://security.debian.org/debian-security|$APT_SECURITY_MIRROR|g; s|https://security.debian.org/debian-security|$APT_SECURITY_MIRROR|g" "$sources"; \
    fi; \
    apt-get update; \
    apt-get install -y --no-install-recommends ca-certificates; \
    rm -rf /var/lib/apt/lists/*

COPY --from=builder /out/codexmanager-web /usr/local/bin/codexmanager-web

ENV CODEXMANAGER_WEB_ADDR=0.0.0.0:48761
ENV CODEXMANAGER_WEB_NO_SPAWN_SERVICE=1
ENV CODEXMANAGER_WEB_NO_OPEN=1
# 默认值适配 docker-compose 的服务名；单独运行时可覆盖为外部 service 的地址。
ENV CODEXMANAGER_SERVICE_ADDR=codexmanager-service:48760
ENV CODEXMANAGER_DB_PATH=/data/codexmanager.db
ENV CODEXMANAGER_RPC_TOKEN_FILE=/data/codexmanager.rpc-token

VOLUME ["/data"]
EXPOSE 48761

CMD ["codexmanager-web"]
